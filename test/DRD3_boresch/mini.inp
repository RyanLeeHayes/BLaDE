
!---------------------------------------------------------------------------
! One iteration of dynamics, called in a loop
!---------------------------------------------------------------------------

structure shake none
run setvariable gamma 0.1
run setvariable dt 0.002
run setvariable T {temp}

run setvariable fnmxtc dcd/{sysname}_prod0.xtc
run setvariable fnmnrg dcd/{sysname}_prod0.nrg
run setvariable fnmlmd res/{sysname}_prod0.lmd
if -f res/{sysname}_prod0.res
  run setvariable fnmcpi res/{sysname}_prod0.res
endif
run setvariable fnmcpo res/{sysname}_prod0.res
run setvariable freqxtc 1 ! 4ps 
run setvariable freqnrg 1
run setvariable freqnpt 100 
run setvariable freqlmd 10
run setvariable hrlmd yes 
run setvariable prettyxtc true ! wrap molecules over pbc 
run setvariable shaketolerance 0.000000001

run setvariable nsteps {min_steps}
run setvariable mintype lbfgs
run setvariable lbfgs_eps .5
run setvariable lbfgs_m 1
run minimize

