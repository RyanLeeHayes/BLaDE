* CHARMM input file for Multi-Site lambda-dynamics
* generated by msld_py_prep (JV,LC) for ALF (RLH)
*


!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
!  Multi-Site Lambda Dynamics 
!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!

set fnex = 5.5 
set sysname = DRD3
set builddir = prep
! set box = BOXSUB
set temp = 298.15
set ligseg = HETA
set resnum = 1

! perturbation variables
set nsites = 1 
set nsubs1 = 2
set nblocks = 2
set nligands = 2

bomblev -2

!! Read in toppar.stream file
system "ln -s prep/toppar toppar"
stream @builddir/toppar.str

! read rtf append card name @builddir/core.rtf
! read param flex append card name @builddir/full_ligand.prm

!! !! Reads coordinates and pdb file for the protein
read sequ pdb name @builddir/protein.pdb
generate PROA first NTER last CTER setup warn
read coor pdb resid name @builddir/protein.pdb

ic generate
ic param
ic build 
hbuild sele hydrogen end
auto angle dihe

!! Reads coordinates and pdb file for the ligand
! read sequ pdb name @builddir/core.pdb
! generate @ligseg setup
! read coor pdb resid name @builddir/core.pdb

!! Read in the ligand patch rtf files
! read rtf append card name @builddir/site1_sub1_pres.rtf
! read rtf append card name @builddir/site1_sub2_pres.rtf
! read rtf append card name @builddir/site1_sub3_pres.rtf

! stream @builddir/mol1.str
! stream @builddir/mol2.str

read param flex append card name @builddir/mol1.prm
read rtf append card name @builddir/mol1.rtf

read param flex append card name @builddir/mol2.prm
read rtf append card name @builddir/mol2.rtf

!read param flex append card name @builddir/mol3.prm
!read rtf append card name @builddir/mol3.rtf

!read param flex append card name @builddir/mol4.prm
!read rtf append card name @builddir/mol4.rtf

!read param flex append card name @builddir/mol5.prm
!read rtf append card name @builddir/mol5.rtf

!read param flex append card name @builddir/mol6.prm
!read rtf append card name @builddir/mol6.rtf

!read param flex append card name @builddir/mol7.prm
!read rtf append card name @builddir/mol7.rtf

!! Read in the ligand fragment pdb files
! ic generate

read sequ card
* Sequence of ligand 1, 2, 3, 4, 5, 6, and 7
*
2
MOL1 MOL2 

generate @ligseg first none last none setup

read coor pdb resid name @builddir/mol1.pdb
read coor pdb resid name @builddir/mol2.pdb
!read coor pdb resid name @builddir/mol3.pdb
!read coor pdb resid name @builddir/mol4.pdb
!read coor pdb resid name @builddir/mol5.pdb
!read coor pdb resid name @builddir/mol6.pdb
!read coor pdb resid name @builddir/mol7.pdb

define site1_sub1 -
 select ( -
 atom @ligseg 1 * -
 ) end

define site1_sub2 -
 select ( -
  atom @ligseg 2 * -
  ) end

!define site1_sub3 -
! select ( -
!  atom @ligseg 3 * -
!  ) end

!define site1_sub4 -
! select ( -
!  atom @ligseg 4 * -
!  ) end

!define site1_sub5 -
! select ( -
!  atom @ligseg 5 * -
!  ) end

!define site1_sub6 -
! select ( -
!  atom @ligseg 6 * -
!  ) end

!define site1_sub7 -
! select ( -
!  atom @ligseg 7 * -
!  ) end

auto angle dihe  !! do not call after deleting sub-sub terms or loading in water
bomblev -1

! delete angles and dihedrals between alchem groups
set ii = 1
label deletesiteloop
if @ii .le. @nsites then

   set jj = 1
   label delete1loop
   if @jj .le. @nsubs@@ii then

      calc kk = @jj + 1
      label delete2loop
      if @kk .le. @nsubs@@ii then

!         dele connectivity sele ( site@{ii}_sub@@jj ) show end sele ( site@{ii}_sub@@kk ) show end
         calc kk = @kk + 1
         goto delete2loop
      endif

      calc jj = @jj + 1
      goto delete1loop
   endif

   calc ii = @ii + 1
   goto deletesiteloop
endif

!! ! System specific deletion (linear groups)
!! dele dihe sele (atom LIG 1 ATOMNAME) show end

!! Load solvent
read sequ pdb name @builddir/solvent.pdb
generate SOLV first none last none setup noangl nodihe
read coor pdb resid name @builddir/solvent.pdb

!! !! Load ions
read sequ pdb name @builddir/ions.pdb
generate IONS first none last none setup noangl nodihe
read coor pdb resid name @builddir/ions.pdb

bomblev 0

!! !! Write Initial System to Disk





write psf card name patch.psf
* patch psf file
*
write coor pdb card name patch.pdb
* patch pdb file
*



!! write coor card name patch.crd
!! * patch crd file
!! *

!! Create water box & periodic images
!! coor stat
!! crystal define cubic @box @box @box 90. 90. 90.
!! crystal build cutoff 14 nope 0
!! image byres xcen 0 ycen 0 zcen 0 sele resn tip3 .or. resn sod .or. resn cla end
!! image byseg xcen 0 ycen 0 zcen 0 sele .not. ( resn tip3 .or. resn sod .or. resn cla ) end

!! Copy main coords into comp set
!! cons harm clear
!! coor copy comp

! LDBI math: for every "pair" there are 5 ldbi's
set ii = 1
set ldbibias = 0
label ldbimathloop
if @ii .le. @nsites then
   calc ldbibias = @ldbibias + ( ( @nsubs@@ii * (@nsubs@@ii - 1) / 2 ) * 5 )
   INCR ii by 1
   goto ldbimathloop
endif
set charge = ?cgtot

! Make sure all atoms have coordinates
print coor sele .not. init end

stream @builddir/step3_pbcsetup.str

! Image Setup
open read unit 10 card name @builddir/crystal_image.str
CRYSTAL DEFINE @XTLtype @A @B @C @alpha @beta @gamma
CRYSTAL READ UNIT 10 CARD


!Image centering by residue
IMAGE BYRESID XCEN @xcen YCEN @ycen ZCEN @zcen sele resname TIP3 end
IMAGE BYRESID XCEN @xcen YCEN @ycen ZCEN @zcen sele segid IONS end

calc blockplusone = @nblocks + 1

!! Build blockassign string for msld command
set blockassign = 0
set prevblock = 0
set ii = 1
label blockassignloop
if @ii .le. @nsites then
   set jj = 1
   label blockassigninner
   if @jj .le. @nsubs@@ii then
      set blockassign = @blockassign @ii
      calc jj = @jj + 1
      goto blockassigninner
   endif
   calc prevblock = @prevblock + @nsubs@@{ii}
   calc ii = @ii + 1
   goto blockassignloop
endif

!! BLOCK setup
BLOCK @blockplusone
   clear
END
BLOCK @blockplusone !RX! NREP @nreps
   Call 2 sele site1_sub1 show end
   Call 3 sele site1_sub2 show end
!   Call 4 sele site1_sub3 show end
!   Call 5 sele site1_sub4 show end
!   Call 6 sele site1_sub5 show end
!   Call 7 sele site1_sub6 show end
!   Call 8 sele site1_sub7 show end


   qldm theta
   lang temp @temp
   !RX! phmd ph 7
   soft on   ! this turns on soft-cores
   pmel ex   ! this turns on PME

   ldin 1 1.0  0.0  5.0  0.0  5.0
   ldin 2  0.3333 0.0  7.5  @lams1s1 10 !RX! NONE
   ldin 3  0.3333 0.0  7.5  @lams1s2 10 !RX! UNEG 7.0
!   ldin 4  0.3333 0.0  7.5  @lams1s3 10 !RX! UPOS 7.0
!   ldin 5  0.3333 0.0  7.5  @lams1s4 10 !RX! UPOS 7.0
!   ldin 6  0.3333 0.0  7.5  @lams1s5 10 !RX! UPOS 7.0
!   ldin 7  0.3333 0.0  7.5  @lams1s6 10 !RX! UPOS 7.0
!   ldin 8  0.3333 0.0  7.5  @lams1s7 10 !RX! UPOS 7.0

   set excl1 = 2 3
   excl @excl1

   !! rmla bond thet dihe impr 
   rmla bond thet impr 
   !! msld 0  1  1  1  fnex @fnex
   msld @blockassign fnpw
   thbv flat all 0.35 59.24 ! width, k
   msma

   ! Check block.doc for functional form of these biasing potentials
   calc nbiaspot = 9 * ( @nblocks * ( @nblocks - 1 ) ) / 2
   ldbi @nbiaspot
   set ibias = 1
   set iblock = 0
   set si = 1
   label loop5_vb
   if @si .le. @nsites then
      set jblock = @iblock
      set sj = @si
      label loop5b_vb
      if @sj .le. @nsites then
         set ii = 1
         label loop6_vb
         if @ii .le. @nsubs@@{si} then
            calc ip1 = @ii + 1 + @iblock
            set jj = 1
            if @si .eq. @sj then
               calc jj = @ii + 1
            endif
            label loop7_vb
            if @jj .le. @nsubs@@{sj} then
               calc jp1 = @jj + 1 + @jblock
   
               set c_shift = 0.0
               set x_shift = 0.0
               set s_shift = 0.0
               !vbrex! if @si .eq. @sj then
               !vbrex!    calc c_shift = 1.2 * (@myrep - @ncentral)
               !vbrex!    calc s_shift = 0.3 * (@myrep - @ncentral)
               !vbrex! endif
            ldbv @ibias @ip1 @jp1 6 0.0 @cs@@{si}s@@{ii}s@@{sj}s@@{jj} 0
            calc ibias = @ibias + 1
            ldbv @ibias @ip1 @jp1 10 -5.56 @xs@@{si}s@@{ii}s@@{sj}s@@{jj} 0
            calc ibias = @ibias + 1
            ldbv @ibias @ip1 @jp1 8 0.012 @ss@@{si}s@@{ii}s@@{sj}s@@{jj} 0
            calc ibias = @ibias + 1
            ldbv @ibias @ip1 @jp1 8 -1.012 @ts@@{si}s@@{ii}s@@{sj}s@@{jj} 0
            calc ibias = @ibias + 1
            ldbv @ibias @ip1 @jp1 12 0.012 @us@@{si}s@@{ii}s@@{sj}s@@{jj} 2
            calc ibias = @ibias + 1
            ldbv @ibias @jp1 @ip1 10 -5.56 @xs@@{sj}s@@{jj}s@@{si}s@@{ii} 0
            calc ibias = @ibias + 1
            ldbv @ibias @jp1 @ip1 8 0.012 @ss@@{sj}s@@{jj}s@@{si}s@@{ii} 0
            calc ibias = @ibias + 1
            ldbv @ibias @jp1 @ip1 8 -1.012 @ts@@{sj}s@@{jj}s@@{si}s@@{ii} 0
            calc ibias = @ibias + 1
            ldbv @ibias @jp1 @ip1 12 0.012 @us@@{sj}s@@{jj}s@@{si}s@@{ii} 2
            calc ibias = @ibias + 1
            calc jj = @jj + 1
            
               goto loop7_vb
            endif
            calc ii = @ii + 1
            goto loop6_vb
         endif
         calc jblock = @jblock + @nsubs@@{sj}
         calc sj = @sj + 1
         goto loop5b_vb
      endif
      calc iblock = @iblock + @nsubs@@{si}
      calc si = @si + 1
      goto loop5_vb
   endif
END

!! !! Set NOE distance restraints
!! NOE
!!    RESET
!! END
!! 
!! faster on
!! !! set up energy parameters if you want to use NOEs
!! nbonds atom fswitch vdw vfswitch cdie eps 1 -
!!     cutnb 14.0 cutim 14.0 ctonnb 10.0 ctofnb 12.0

!! energy
!! NOE
!! ! Site 1
!!    assign sele atom LIG 1 Atom1 end sele atom LIG 1 Atom2 end -
!!    kmin 1.0 rmin 0.0 kmax 1.0 rmax 0.2 fmax 2.0 rswitch 2.0 sexp 1.0
!! 
!!    print anal
!! END


!! Boresch Restraints
!!

set lig = 1

label reiterate_ligand

calc ligblock = @lig + 1

stream @builddir/boresch_variables@{lig}.str

MMFP

GEO sphere RCM distance -
   harmonic symmetric force -@distancek droff @distance block @ligblock -
   select atom @ligsegid @lig @l1name end -
   select atom @protsegid @p1resnum @p1name end

GEO sphere RCM angle -
   harmonic symmetric force -@thetaak tref @thetaa dtoff 0.0 block @ligblock -
   select atom @ligsegid @lig @l1name end -
   select atom @protsegid @p1resnum @p1name end -
   select atom @protsegid @p2resnum @p2name end

GEO sphere RCM angle -
   harmonic symmetric force -@thetabk tref @thetab dtoff 0.0 block @ligblock -
   select atom @ligsegid @lig @l2name end -
   select atom @ligsegid @lig @l1name end -
   select atom @protsegid @p1resnum @p1name end

GEO sphere RCM dihedral -
   harmonic symmetric force -@phiak tref @phia dtoff 0.0 block @ligblock -
   select atom @ligsegid @lig @l1name end -
   select atom @protsegid @p1resnum @p1name end -
   select atom @protsegid @p2resnum @p2name end -
   select atom @protsegid @p3resnum @p3name end

GEO sphere RCM dihedral -
   harmonic symmetric force -@phibk tref @phib dtoff 0.0 block @ligblock -
   select atom @ligsegid @lig @l2name end -
   select atom @ligsegid @lig @l1name end -
   select atom @protsegid @p1resnum @p1name end -
   select atom @protsegid @p2resnum @p2name end

GEO sphere RCM dihedral -
   harmonic symmetric force -@phick tref @phic dtoff 0.0 block @ligblock -
   select atom @ligsegid @lig @l3name end -
   select atom @ligsegid @lig @l2name end -
   select atom @ligsegid @lig @l1name end -
   select atom @protsegid @p1resnum @p1name end

GEO sphere RCM distance -
   harmonic symmetric force @distancek droff @distance -
   select atom @ligsegid @lig @l1name end -
   select atom @protsegid @p1resnum @p1name end

GEO sphere RCM angle -
   harmonic symmetric force @thetaak tref @thetaa dtoff 0.0 -
   select atom @ligsegid @lig @l1name end -
   select atom @protsegid @p1resnum @p1name end -
   select atom @protsegid @p2resnum @p2name end

GEO sphere RCM angle -
   harmonic symmetric force @thetabk tref @thetab dtoff 0.0 -
   select atom @ligsegid @lig @l2name end -
   select atom @ligsegid @lig @l1name end -
   select atom @protsegid @p1resnum @p1name end

GEO sphere RCM dihedral -
   harmonic symmetric force @phiak tref @phia dtoff 0.0 -
   select atom @ligsegid @lig @l1name end -
   select atom @protsegid @p1resnum @p1name end -
   select atom @protsegid @p2resnum @p2name end -
   select atom @protsegid @p3resnum @p3name end

GEO sphere RCM dihedral -
   harmonic symmetric force @phibk tref @phib dtoff 0.0 -
   select atom @ligsegid @lig @l2name end -
   select atom @ligsegid @lig @l1name end -
   select atom @protsegid @p1resnum @p1name end -
   select atom @protsegid @p2resnum @p2name end

GEO sphere RCM dihedral -
   harmonic symmetric force @phick tref @phic dtoff 0.0 -
   select atom @ligsegid @lig @l3name end -
   select atom @ligsegid @lig @l2name end -
   select atom @ligsegid @lig @l1name end -
   select atom @protsegid @p1resnum @p1name end
END

incr lig

if @lig .le. @nligands goto reiterate_ligand
