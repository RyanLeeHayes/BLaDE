! Test per-block friction and partial FFIX in standalone BLaDE parser
! Uses RNaseH_peptide 1-site, 2-sub system (3 blocks: env + 2 subs)

verbose 0

variables set restartfile null
variables set DIR .
variables set esteps 500
variables set nsteps 500

variables set fnex 5.5
variables set temp 298.15

stream {DIR}/variablesflat.inp

stream {DIR}/prep/{sysname}.inp

! Set nonbonded options
run setvariable rswitch 9.0
run setvariable rcut 10.0
run setvariable invbetaewald 3.125
run setvariable orderewald 6
run setvariable gridspace 1.1

coordinates file pdb {DIR}/prep/minimized.pdb
coordinates velocity {temp}

!---------------------------------------------------------------------------
! Setup of dynamics run
!---------------------------------------------------------------------------

structure shake hbond
run setvariable gamma 5.0
run setvariable shaketolerance 0.0000002

! Set MSLD gamma so thetaFriction array gets proper default
msld gamma 5.0

! Override block initial conditions: set theta=0.3 for block 1 (will be fixed lambda)
! For fixed blocks, theta IS the lambda value directly
!               B S   t0  tv  tm  fb   q
msld initialize 1 1 0.3 0 5 0 0
msld initialize 2 1 0.3 0 5 0 0

! Test per-block friction: set block 1 friction to 9999 ps^-1
msld friction 1 9999.0

! Test partial FFIX: fix block 1 lambda at 0.3
msld fix 1

run setvariable fnmxtc test_ffix.xtc
run setvariable fnmnrg test_ffix.nrg
run setvariable fnmlmd test_ffix.lmd
run setvariable fnmcpo test_ffix.res

run setvariable nsteps 500
run setvariable dt 0.002
run setvariable T {temp}
run setvariable freqxtc 500
run setvariable freqnrg 100
run setvariable freqnpt 0
run setvariable freqlmd 10
run setvariable hrlmd yes
run setvariable domdecheuristic off
run dynamics
